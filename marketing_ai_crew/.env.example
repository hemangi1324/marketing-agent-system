# ============================================================
# REQUIRED — Gemini API Key required for running agents
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# OPTIONAL — Only needed if switching LLM provider
# ============================================================
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=your_groq_api_key_here
# ANTHROPIC_API_KEY=sk-ant-...   # For Claude (paid)
# OLLAMA_BASE_URL=http://localhost:11434  # For local Ollama (free)

# ============================================================
# OPTIONAL — Real integrations (leave blank to use mocks)
# ============================================================
# SERPER_API_KEY=           # Real web search ($50/mo)
# HUBSPOT_API_KEY=          # Real CRM
# BUFFER_ACCESS_TOKEN=      # Real social scheduling
# MAILCHIMP_API_KEY=        # Real email campaigns
# GOOGLE_ADS_DEVELOPER_TOKEN=  # Real ads management

# ============================================================
# App settings
# ============================================================
LLM_PROVIDER=gemini            # gemini | openai | groq | ollama
LLM_MODEL=gemini-2.5-flash     # Recommended starting model for Gemini
OUTPUT_DIR=outputs
FLASK_PORT=5000
