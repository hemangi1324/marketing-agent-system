# ============================================================
# REQUIRED — Gemini API Key required for running agents
# ============================================================
GEMINI_API_KEY=AIzaSyCbQRN7xAWmWJrmavVij_uxt9cv5DgHMtY

# ============================================================
# OPTIONAL — Only needed if switching LLM provider
# ============================================================
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=your_groq_api_key_here
# ANTHROPIC_API_KEY=sk-ant-...   # For Claude (paid)
# OLLAMA_BASE_URL=http://localhost:11434  # For local Ollama (free)

# ============================================================
# OPTIONAL — Real integrations (leave blank to use mocks)
# ============================================================
# SERPER_API_KEY=           # Real web search ($50/mo)
# HUBSPOT_API_KEY=          # Real CRM
# BUFFER_ACCESS_TOKEN=      # Real social scheduling
# MAILCHIMP_API_KEY=        # Real email campaigns
# GOOGLE_ADS_DEVELOPER_TOKEN=  # Real ads management

# ============================================================
# App settings
# ============================================================
LLM_PROVIDER=gemini            # gemini | openai | groq | ollama
LLM_MODEL=gemini-2.5-flash     # Recommended starting model for Gemini
OUTPUT_DIR=outputs
FLASK_PORT=5000

# ============================================================
# EMAIL AUTOMATION (SMTP) — Required for the email pipeline
# ============================================================

# Your sender email address
EMAIL_USER=your_email@gmail.com

# For Gmail: use a 16-character App Password (NOT your regular password)
# Steps: Google Account → Security → 2-Step Verification → App Passwords
# For Outlook/Hotmail: use your regular password + smtp-mail.outlook.com
# For Zoho: use smtp.zoho.com with your Zoho credentials
EMAIL_PASS=your_16_char_app_password_here

# SMTP server settings (defaults shown are for Gmail — change for other providers)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Friendly sender name shown in recipients' inboxes
EMAIL_SENDER_NAME=Marketing AI Crew

# ============================================================
# OPTIONAL — Slack Alerts (for risk agent notifications)
# ============================================================
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================
# OPTIONAL — Database (future recipient list integration)
# ============================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/marketing_db
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=password
# DB_NAME=marketing_db
